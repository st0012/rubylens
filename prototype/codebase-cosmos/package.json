{
  "name": "rubylens-codebase-cosmos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "generate:data": "node --max-old-space-size=2048 scripts/generate-art-fixture.mjs",
    "check:data": "node --max-old-space-size=2048 scripts/generate-art-fixture.mjs --check",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run check:data && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/three": "0.185.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
