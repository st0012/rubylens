#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../lib/rubylens"

options = {}
parser = OptionParser.new do |arguments|
  arguments.banner = "Usage: rubylens-compare CONTROL_SUMMARY WORKSPACE_SUMMARY --output FILE"
  arguments.on("--output FILE", "Comparison JSON path") { |value| options[:output] = value }
end
parser.parse!
control, workspace = ARGV
if control.nil? || workspace.nil? || options[:output].nil? || ARGV.length != 2
  warn parser
  exit 2
end

comparison = RubyLens::Comparison.new(
  control_summary: control,
  workspace_summary: workspace,
  output_path: options.fetch(:output),
).run
puts JSON.generate(comparison.fetch("dependency_proof"))
