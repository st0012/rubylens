#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "../lib/rubylens"
require_relative "../lib/rubylens/mcp_probe"

options = {}
parser = OptionParser.new do |arguments|
  arguments.banner = "Usage: rubylens-mcp-probe TARGET --output FILE [--summary FILE] [--profile NAME]"
  arguments.on("--output FILE", "MCP probe JSON path") { |value| options[:output] = value }
  arguments.on("--summary FILE", "Workspace summary used for exact aggregate reconciliation") do |value|
    options[:summary] = value
  end
  arguments.on("--profile NAME", RubyLens::MCPProbe::PROFILES.keys, "Representative call profile") do |value|
    options[:profile] = value
  end
end
parser.parse!
target = ARGV.shift
if target.nil? || options[:output].nil? || !ARGV.empty?
  warn parser
  exit 2
end

payload = RubyLens::MCPProbe.new(
  target_root: target,
  output_path: options.fetch(:output),
  summary_path: options[:summary],
  profile: options[:profile],
).run
puts JSON.generate(payload.slice("rubydex_version", "tool", "index_seconds", "stats", "response_is_error"))
